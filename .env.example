# Copy this to .env and fill in your own eBay developer credentials.
# Do not commit .env.

# Use production keys for real ebay.com.au sold prices.
# Sandbox keys are useful for plumbing checks but usually will not return real AU marketplace data.
EBAY_ENV=production
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_AU
EBAY_SCOPE=https://api.ebay.com/oauth/api_scope/buy.marketplace.insights
